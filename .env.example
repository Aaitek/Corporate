# Frontend (Vite) — copy to `.env` or `.env.local` (gitignored).

# Use hosted Strapi from local dev (no Strapi on localhost):
# Set to your Railway app origin only — no trailing slash, no `/api` suffix.
# VITE_STRAPI_PROXY_TARGET=https://your-corporate-service.up.railway.app

# Optional legacy override for image URLs if you do not use VITE_STRAPI_PROXY_TARGET:
# VITE_API_URL=https://your-corporate-service.up.railway.app
