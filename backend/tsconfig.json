{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": false,
    "rootDir": ".",
    "outDir": "build"
  },
  "include": ["src/**/*.js", "types/**/*.d.ts"],
  "exclude": ["node_modules", "build", ".cache", ".tmp"]
}
