HOST=0.0.0.0
PORT=1337
NODE_ENV=development
# Railway: set PUBLIC_URL to your service URL (admin + cookies). Railway often omits NODE_ENV=production.
# PUBLIC_URL=https://your-service.up.railway.app
# BEHIND_PROXY=true
APP_KEYS=toBeModified1,toBeModified2,toBeModified3,toBeModified4
API_TOKEN_SALT=toBeModified
ADMIN_JWT_SECRET=toBeModified
TRANSFER_TOKEN_SALT=toBeModified
JWT_SECRET=toBeModified

# PostgreSQL — pick ONE approach:
#
# A) Railway public URL (local dev + proxy host). Copy from Postgres → Connect in Railway.
# DATABASE_PUBLIC_URL=postgresql://USER:PASSWORD@HOST:PORT/railway
#
# B) Discrete vars (e.g. local Postgres)
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=aaitek
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=
# DATABASE_SSL=false
