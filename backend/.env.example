# Local dev: copy to .env and fill in real values. Do not commit .env.

HOST=0.0.0.0
PORT=1337
NODE_ENV=development
# How you open the admin in the browser (no trailing slash)
PUBLIC_URL=http://localhost:1337
# Not behind a reverse proxy on your machine
BEHIND_PROXY=false

# Strapi secrets (match Railway "Corporate" or generate new for local-only)
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=changeMe
ADMIN_JWT_SECRET=changeMe
TRANSFER_TOKEN_SALT=changeMe
JWT_SECRET=changeMe

# ---------------------------------------------------------------------------
# Option A — hosted Postgres (Railway) from your PC
# 1) Railway → your PostgreSQL service (the database) → Variables
# 2) Copy DATABASE_PUBLIC_URL (host is like *.proxy.rlwy.net, NOT *.railway.internal)
# 3) If you do not see it, open the DB service → enable public URL / check Connect tab
# 4) In this file ONLY use the line below for DB — remove PGHOST/PGPORT/PGDATABASE/PGUSER/PGPASSWORD if they point at postgres.railway.internal
# DATABASE_PUBLIC_URL=postgresql://USER:PASSWORD@SHORT.proxy.rlwy.net:PORT/railway
DATABASE_SSL=true
